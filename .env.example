# === Project ===
COMPOSE_PROJECT_NAME=vanyabot

# === Database (local Docker PostgreSQL) ===
DB_NAME=vanyabot
DB_USER=app
DB_PASSWORD=changeme
# DATABASE_URL is auto-assembled in compose.yml — do not set here

# === Telegram ===
BOT_TOKEN=your_telegram_bot_token
CHANNEL_ID=-1002504147240
CHANNEL_USERNAME=ivanfit_health

# === OpenRouter (LLM) ===
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=google/gemini-3-flash-preview

# === Payment ===
TRIBUTE_LINK=https://t.me/tribute/app?startapp=pnvi
# ZIINA_LINK=https://pay.ziina.com/your-link
# ZIINA_WEBHOOK_SECRET=your_ziina_secret

# === Logging ===
LOG_LEVEL=DEBUG                          # prod: WARN

# === Dev Ports (compose.override.yml) ===
# BACKEND_PORT=3001
# FRONTEND_PORT=5173
# DB_PORT=5432

# === Production (uncomment for docker deploy) ===
# APP_PORT=80
# DOCKER_REGISTRY=ghcr.io
# DOCKER_IMAGE=vanyabot
# VERSION=latest
